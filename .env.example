# ── Mode A: Docker all-in-one (recommended — no extra terminals) ─────────────
# Double-click Start-AniStream.bat or run: npm start
# Open http://localhost
PUBLIC_URL=http://localhost

# ── Mode B: Vite dev (hot reload) — needs 2 extra terminals ───────────────────
# docker compose up -d miruro consumet animetsu
# cd gateway && npm run dev
# cd web && npm run dev
# Open http://localhost:5173
# PUBLIC_URL=http://localhost:8787

CORS_ORIGIN=*

ANIPUB_URL=https://anipub.xyz

MIRURO_URL=http://localhost:8000
MIRURO_API_KEY=anistream-local-miruro-key

ZENSHIN_URL=https://zenshin-supabase-api.onrender.com
ZENSHIN_URL_FALLBACK=https://zenshin-supabase-api-myig.onrender.com

STREAM_PREFER_EMBED=true

CONSUMET_URL=http://localhost:3000
ANIMETSU_URL=http://localhost:8080
# ENABLE_ANIMEPAHE=true
# ANIMEPAHE_BASE_URL=https://animepahe.com
